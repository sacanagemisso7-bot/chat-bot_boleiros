# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=seu_verify_token
META_WHATSAPP_TOKEN=seu_token_permanente
META_PHONE_NUMBER_ID=123456789012345
META_APP_SECRET=seu_app_secret
META_VALIDATE_SIGNATURE=false
META_GRAPH_VERSION=v22.0

# Banco local SQLite
DB_PATH=barbearia.db

# OpenAI (opcional)
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_CONTEXT_MESSAGES=8
OPENAI_TEMPERATURE=0.2

# Endpoints internos de debug (desative em produção)
DEBUG_ENDPOINTS_ENABLED=true
